# ===========================================
# AI Attendance System - Environment Example
# ===========================================
# Copy to .env and set values. Never commit .env.

# ---- Backend (FastAPI) ----
SECRET_KEY=your-secret-key-use-openssl-rand-hex-32
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=attendance_user
MYSQL_PASSWORD=secure_password_here
MYSQL_DATABASE=ai_attendance

# Optional: full URL (overrides above)
# DATABASE_URL=mysql+aiomysql://user:pass@host:3306/dbname

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Face recognition
FACE_ENCODING_TOLERANCE=0.5
FACE_DETECTION_MODEL=hog

# ---- Frontend (build-time) ----
# VITE_API_URL=/api/v1
# For production: VITE_API_URL=https://api.yourdomain.com/api/v1

# ---- Initial admin (scripts/init_db.py) ----
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin@123
