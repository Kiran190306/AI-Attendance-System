### Backend environment variables example for production
# Copy this file to `backend/.env` and set appropriate values for your environment.

# App
APP_NAME=AI Attendance System
DEBUG=false
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=replace-with-secure-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000

# Database (MySQL or provide DATABASE_URL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=attendance_user
MYSQL_PASSWORD=attendance_pass
MYSQL_DATABASE=ai_attendance
# or use full URL
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# Recognition module DB (optional override)
RECORDS_DB_PATH=attendance_log.db
