# Local System Configuration
# Copy this file to .env and update with your settings

# Cloud Backend URL
CLOUD_API_URL=https://your-app.onrender.com

# Enable Cloud Sync (true/false)
CLOUD_SYNC_ENABLED=true

# Local Attendance CSV Path
ATTENDANCE_CSV_PATH=./attendance/attendance.csv

# Sync Configuration
SYNC_BATCH_SIZE=10
SYNC_INTERVAL_SECONDS=5
SYNC_MAX_RETRIES=5
